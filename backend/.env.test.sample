# Copy to backend/.env.test and use it only for automated tests.
# The database name must not be the development or demonstration database.
APP_NAME=My-eBookStore API Test
API_PREFIX=/api
SQLSERVER_DRIVER=ODBC Driver 17 for SQL Server
SQLSERVER_SERVER=localhost\MYDB
SQLSERVER_DATABASE=My_eBookStore_Test
SQLSERVER_TRUSTED_CONNECTION=yes
SQLSERVER_TRUST_SERVER_CERTIFICATE=yes
JWT_SECRET_KEY=test-only-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
